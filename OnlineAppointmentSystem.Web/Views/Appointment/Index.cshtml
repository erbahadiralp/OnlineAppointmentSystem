@model OnlineAppointmentSystem.Web.Models.AppointmentViewModels.AppointmentListViewModel
@{
    ViewData["Title"] = "Randevularım";
}

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <a asp-action="Create" class="btn btn-success">Yeni Randevu</a>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-12">
                <form asp-action="Index" method="get" class="form-inline">
                    <div class="input-group mr-2 mb-2">
                        <input type="text" name="SearchTerm" class="form-control" placeholder="Ara..." value="@Model.SearchTerm">
                        <div class="input-group-append">
                            <button class="btn btn-outline-secondary" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>
                    <select name="StatusFilter" class="form-control mr-2 mb-2" onchange="this.form.submit()">
                        <option value="">Tüm Durumlar</option>
                        <option value="Pending" @(Model.StatusFilter == "Pending" ? "selected" : "")>Bekliyor</option>
                        <option value="Confirmed" @(Model.StatusFilter == "Confirmed" ? "selected" : "")>Onaylandı</option>
                        <option value="Completed" @(Model.StatusFilter == "Completed" ? "selected" : "")>Tamamlandı</option>
                        <option value="Cancelled" @(Model.StatusFilter == "Cancelled" ? "selected" : "")>İptal Edildi</option>
                    </select>
                    <select name="DateFilter" class="form-control mr-2 mb-2" onchange="this.form.submit()">
                        <option value="">Tüm Tarihler</option>
                        <option value="Today" @(Model.DateFilter == "Today" ? "selected" : "")>Bugün</option>
                        <option value="Tomorrow" @(Model.DateFilter == "Tomorrow" ? "selected" : "")>Yarın</option>
                        <option value="ThisWeek" @(Model.DateFilter == "ThisWeek" ? "selected" : "")>Bu Hafta</option>
                        <option value="NextWeek" @(Model.DateFilter == "NextWeek" ? "selected" : "")>Gelecek Hafta</option>
                        <option value="ThisMonth" @(Model.DateFilter == "ThisMonth" ? "selected" : "")>Bu Ay</option>
                    </select>
                    <button type="submit" class="btn btn-primary mb-2">Filtrele</button>
                    <a asp-action="Index" class="btn btn-outline-secondary mb-2 ml-2">Filtreleri Temizle</a>
                </form>
            </div>
        </div>

        @if (Model.Appointments.Count == 0)
        {
            <div class="alert alert-info">
                Randevu bulunamadı.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="thead-dark">
                        <tr>
                            <th>Tarih</th>
                            <th>Hizmet</th>
                            <th>Çalışan</th>
                            <th>Durum</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appointment in Model.Appointments)
                        {
                            <tr>
                                <td>@appointment.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@appointment.ServiceName</td>
                                <td>@appointment.EmployeeName</td>
                                <td>
                                    @{
                                        string badgeClass = appointment.Status switch
                                        {
                                            OnlineAppointmentSystem.Entity.Enums.AppointmentStatus.Pending => "badge-warning",
                                            OnlineAppointmentSystem.Entity.Enums.AppointmentStatus.Confirmed => "badge-success",
                                            OnlineAppointmentSystem.Entity.Enums.AppointmentStatus.Completed => "badge-info",
                                            OnlineAppointmentSystem.Entity.Enums.AppointmentStatus.Cancelled => "badge-danger",
                                            _ => "badge-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@appointment.StatusName</span>
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@appointment.AppointmentId" class="btn btn-sm btn-info">
                                            <i class="bi bi-info-circle"></i>
                                        </a>
                                        @if (appointment.Status == OnlineAppointmentSystem.Entity.Enums.AppointmentStatus.Pending)
                                        {
                                            <a asp-action="Edit" asp-route-id="@appointment.AppointmentId" class="btn btn-sm btn-primary">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Cancel" asp-route-id="@appointment.AppointmentId" class="btn btn-sm btn-danger">
                                                <i class="bi bi-x-circle"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>