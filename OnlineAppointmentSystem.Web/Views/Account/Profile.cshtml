@model OnlineAppointmentSystem.Entity.DTOs.UserDTO
@{
    ViewData["Title"] = "Profil";
}

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Profil Bilgileri</h5>
            </div>
            <div class="card-body">
                <div class="text-center mb-4">
                    <i class="bi bi-person-circle" style="font-size: 5rem;"></i>
                </div>
                <h4 class="text-center">@Model.FirstName @Model.LastName</h4>
                <p class="text-center text-muted">@Model.Role</p>
                <hr />
                <dl class="row">
                    <dt class="col-sm-4">Email:</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">Telefon:</dt>
                    <dd class="col-sm-8">@Model.PhoneNumber</dd>
                    <dt class="col-sm-4">Adres:</dt>
                    <dd class="col-sm-8">@Model.Address</dd>
                </dl>
            </div>
            <div class="card-footer">
                <a href="#" class="btn btn-primary btn-block">Profili D³zenle</a>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Randevular²m</h5>
            </div>
            <div class="card-body">
                <a asp-controller="Appointments" asp-action="Index" class="btn btn-info mb-3">T³m Randevular²m² G÷r³nt³le</a>
                <a asp-controller="Appointments" asp-action="Create" class="btn btn-success mb-3 ml-2">Yeni Randevu Al</a>
            </div>
        </div>
    </div>
</div>