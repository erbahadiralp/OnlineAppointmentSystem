@model OnlineAppointmentSystem.Entity.DTOs.WorkingHoursDTO

@{
    ViewData["Title"] = "Sil";
}

<h2>Çalışma Saati Sil</h2>

<h4>@Model.EmployeeName - @Model.DayName</h4>

<dl class="row">
    <dt class="col-sm-2">Başlangıç</dt>
    <dd class="col-sm-10">@Model.StartTime</dd>

    <dt class="col-sm-2">Bitiş</dt>
    <dd class="col-sm-10">@Model.EndTime</dd>

    <dt class="col-sm-2">Aktif</dt>
    <dd class="col-sm-10">@((Model.IsActive) ? "Evet" : "Hayır")</dd>
</dl>

<form asp-action="DeleteConfirmed">
    <input type="hidden" asp-for="WorkingHoursId" />
    <button type="submit" class="btn btn-danger">Sil</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>
