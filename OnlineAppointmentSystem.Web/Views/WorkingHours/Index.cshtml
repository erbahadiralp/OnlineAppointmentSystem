@model IEnumerable<OnlineAppointmentSystem.Entity.DTOs.WorkingHoursDTO>

@{
    ViewData["Title"] = "Çalışma Saatleri";
}

<h2>Çalışma Saatleri</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Yeni Çalışma Saati Ekle</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Çalışan</th>
            <th>Gün</th>
            <th>Başlangıç</th>
            <th>Bitiş</th>
            <th>Aktif</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EmployeeName</td>
                <td>@item.DayName</td>
                <td>@item.StartTime</td>
                <td>@item.EndTime</td>
                <td>@(item.IsActive ? "Evet" : "Hayır")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.WorkingHoursId" class="btn btn-info btn-sm">Detay</a>
                    <a asp-action="Edit" asp-route-id="@item.WorkingHoursId" class="btn btn-warning btn-sm">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@item.WorkingHoursId" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
