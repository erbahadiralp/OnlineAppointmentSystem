@model IEnumerable<OnlineAppointmentSystem.Entity.DTOs.EmployeeDTO>
@{
    ViewData["Title"] = "Çalışanlar";
}

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <a asp-action="Create" class="btn btn-success">Yeni Çalışan</a>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
                <div class="alert alert-info">
                    Kayıtlı çalışan bulunamadı.
                </div>
        }
        else
        {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="thead-dark">
                            <tr>
                                <th>Ad Soyad</th>
                                <th>Email</th>
                                <th>Telefon</th>
                                <th>Bölüm</th>
                                <th>Ünvan</th>
                                <th>Durum</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var emp in Model)
                        {
                                    <tr>
                                        <td>@emp.FirstName @emp.LastName</td>
                                        <td>@emp.Email</td>
                                        <td>@emp.PhoneNumber</td>
                                        <td>@emp.Department</td>
                                        <td>@emp.Title</td>
                                        <td>
                                    @if (emp.IsActive)
                                    {
                                                    <span class="badge badge-success">Aktif</span>
                                    }
                                    else
                                    {
                                                    <span class="badge badge-danger">Pasif</span>
                                    }
                                        </td>
                                        <td>
                                            <div class="btn-group">
                                                <a asp-action="Details" asp-route-id="@emp.EmployeeId" class="btn btn-sm btn-info">
                                                    <i class="bi bi-info-circle"></i>
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@emp.EmployeeId" class="btn btn-sm btn-primary">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@emp.EmployeeId" class="btn btn-sm btn-danger">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                        @if (emp.IsActive)
                                        {
                                                        <form asp-action="Deactivate" asp-route-id="@emp.EmployeeId" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-sm btn-warning" title="Pasifleştir">
                                                                <i class="bi bi-toggle-off"></i>
                                                            </button>
                                                        </form>
                                        }
                                        else
                                        {
                                                        <form asp-action="Activate" asp-route-id="@emp.EmployeeId" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-sm btn-success" title="Aktifleştir">
                                                                <i class="bi bi-toggle-on"></i>
                                                            </button>
                                                        </form>
                                        }
                                            </div>
                                        </td>
                                    </tr>
                        }
                        </tbody>
                    </table>
                </div>
        }
    </div>
</div>
