@model OnlineAppointmentSystem.Web.Models.EmployeeViewModels.EmployeeCreateViewModel

@{
    ViewData["Title"] = "Yeni Çalışan Oluştur";
}

<div class="container mt-5">
    <div class="card shadow rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h3 class="mb-0">Yeni Çalışan Oluştur</h3>
        </div>
        <div class="card-body p-4">

            <form asp-action="Create" method="post" class="row g-3">

                <div class="col-md-6">
                    <label asp-for="UserId" class="form-label">Kullanıcı</label>
                    <select asp-for="UserId" class="form-select" asp-items="Model.Users">
                        <option value="">-- Kullanıcı Seçin --</option>
                    </select>
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Title" class="form-label">Ünvan</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Department" class="form-label">Departman</label>
                    <input asp-for="Department" class="form-control" />
                    <span asp-validation-for="Department" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="ServiceIds" class="form-label">Hizmetler</label>
                    <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                        @foreach (var service in Model.Services.OrderBy(s => s.Text))
                        {
                            var serviceId = Convert.ToInt32(service.Value);
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       name="ServiceIds"
                                       value="@serviceId"
                                       id="service_@serviceId"
                                @(Model.ServiceIds.Contains(serviceId) ? "checked" : "") />
                                <label class="form-check-label" for="service_@serviceId">
                                    @service.Text
                                </label>
                            </div>
                        }
                    </div>
                    <span asp-validation-for="ServiceIds" class="text-danger"></span>
                </div>

                <div class="col-12 text-end">
                    <button type="submit" class="btn btn-success">Kaydet</button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">İptal</a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
