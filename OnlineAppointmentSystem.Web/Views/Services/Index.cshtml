@model IEnumerable<OnlineAppointmentSystem.Entity.DTOs.ServiceDTO>
@{
    ViewData["Title"] = "Hizmetler";
}

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <a asp-action="Create" class="btn btn-success">Yeni Hizmet</a>
    </div>
    <div class="card-body">
        @if (Model.Count() == 0)
        {
            <div class="alert alert-info">
                Kayıtlı hizmet bulunamadı.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="thead-dark">
                        <tr>
                            <th>Hizmet Adı</th>
                            <th>Açıklama</th>
                            <th>Fiyat</th>
                            <th>Süre (dk)</th>
                            <th>Durum</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var service in Model)
                        {
                            <tr>
                                <td>@service.ServiceName</td>
                                <td>@(service.Description.Length > 50 ? service.Description.Substring(0, 50) + "..." : service.Description)</td>
                                <td>@service.Price.ToString("C")</td>
                                <td>@service.Duration</td>
                                <td>
                                    @if (service.IsActive)
                                    {
                                        <span class="badge badge-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Pasif</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group">              
                                        <a asp-action="Edit" asp-route-id="@service.ServiceId" class="btn btn-sm btn-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@service.ServiceId" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                        @if (service.IsActive)
                                        {
                                            <form asp-action="Deactivate" asp-route-id="@service.ServiceId" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-warning">
                                                    <i class="bi bi-toggle-off"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Activate" asp-route-id="@service.ServiceId" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="bi bi-toggle-on"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>