@model IEnumerable<OnlineAppointmentSystem.Entity.DTOs.ServiceDTO>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white py-3 px-4">
                <h5 class="mb-0">Hizmetlerimiz</h5>
            </div>
            <div class="card-body bg-light px-4 py-4">
                <div class="row g-3">
                    @foreach (var service in Model)
                    {
                        <div class="col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body p-3 d-flex align-items-center justify-content-center text-center">
                                    <h5 class="card-title fw-semibold text-primary mb-0">@service.ServiceName</h5>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <br />
                <div class="mt-4 text-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Appointments" asp-action="Create" class="btn btn-primary w-">Randevu Al</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary w-25">Giriş Yaparak Randevu Alabilirsiniz</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
